# Copy this file to .env and fill in real values.
# NEVER commit the real .env to git.

# ===== Required =====
# Master M3 API key from the developer console (MiniMax Token Plan).
M3_API_KEY=

# Upstream base URL (override only if you proxy M3 internally).
M3_BASE_URL=https://api.MiniMax.com

# ===== CORS =====
# Comma-separated origins. Use your deployed frontend URL in production.
ALLOWED_ORIGINS=https://your-frontend.example.com,http://localhost:5173

# ===== Network =====
# Per-request timeout in seconds.
M3_TIMEOUT_SECONDS=60

# Per-IP requests per minute. Set to 0 to disable.
RATE_LIMIT_PER_MIN=60

# Port the server listens on.
PORT=8000

# ===== Caching (non-streaming, no per-user-key requests only) =====
CACHE_TTL_SECONDS=300
CACHE_MAX_ENTRIES=128

# ===== Logging =====
SERVICE_NAME=m3-proxy
LOG_LEVEL=INFO
# Set LOG_JSON=true in production. Defaults to pretty console output.
LOG_JSON=false

# ===== Observability (optional) =====
# Leave blank to disable.

# Sentry — error reporting.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_RELEASE=m3-proxy@1.1.0

# OpenTelemetry — distributed tracing.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
